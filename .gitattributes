# Normalize all text files to LF
* text=auto eol=lf

# Go source
*.go text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch files
*.bat text eol=crlf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# GitHub Actions
.github/** text eol=lf